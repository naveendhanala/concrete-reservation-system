# Server
NODE_ENV=development
PORT=4000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=concrete_reservation
DB_USER=concrete_user
DB_PASSWORD=concrete_pass
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email (use Mailtrap for dev, SES/SendGrid for prod)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@concrete-system.com

# App Config
DEFAULT_CUTOFF_HOURS=4
DEFAULT_SHIFT_START=06:00
DEFAULT_SHIFT_END=22:00
DEFAULT_SLOT_DURATION_MINUTES=60
DEFAULT_PLANT_CAPACITY_M3_PER_HOUR=60
