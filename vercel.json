{
  "version": 2,
  "installCommand": "npm install --prefix backend && npm install --prefix frontend --include=dev",
  "buildCommand": "(cd frontend && npm run build)",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/generate-slots",
      "schedule": "0 18 * * *"
    }
  ]
}
