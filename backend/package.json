{
  "name": "concrete-reservation-backend",
  "version": "1.0.0",
  "description": "Concrete Reservation System - Backend API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node src/db/migrate.js",
